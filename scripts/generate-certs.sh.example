#!/bin/bash
# Generate TLS certificates for OpenLDAP
# Creates CA, server certificate, and key for LDAPS
#
# Usage:
#   LDAP_DOMAIN=example.com \
#   LDAP_HOST=ldap.yourdomain.com \
#   CERT_DAYS=3650 \
#   ./generate-certs.sh

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
CERT_DIR="${PROJECT_DIR}/certs"

# Configuration
LDAP_DOMAIN="${LDAP_DOMAIN:-example.com}"
LDAP_HOST="${LDAP_HOST:-localhost}"
CERT_DAYS="${CERT_DAYS:-3650}"

echo "=========================================="
echo "TLS Certificate Generation"
echo "=========================================="
echo "Certificate directory: ${CERT_DIR}"
echo "Domain: ${LDAP_DOMAIN}"
echo "Host: ${LDAP_HOST}"
echo "Validity: ${CERT_DAYS} days"
echo ""

mkdir -p "${CERT_DIR}"
cd "${CERT_DIR}"

# Generate CA key and certificate
echo "1. Generating CA certificate..."
if [ ! -f "ca.key" ]; then
    openssl genrsa -out ca.key 4096
    openssl req -new -x509 -days ${CERT_DAYS} -key ca.key -out ca.crt \
        -subj "/C=CN/ST=Beijing/L=Beijing/O=${LDAP_DOMAIN}/OU=IT/CN=CA"
    echo "[OK] CA certificate generated"
else
    echo "[SKIP] CA certificate already exists"
fi
echo ""

# Generate LDAP server key and CSR
echo "2. Generating LDAP server certificate..."
if [ ! -f "ldap.key" ]; then
    openssl genrsa -out ldap.key 4096

    # Create SAN configuration
    cat > ldap.cnf <<EOF
[req]
distinguished_name = req_distinguished_name
req_extensions = v3_req
prompt = no

[req_distinguished_name]
C = CN
ST = Beijing
L = Beijing
O = ${LDAP_DOMAIN}
OU = IT
CN = ${LDAP_HOST}

[v3_req]
basicConstraints = CA:FALSE
keyUsage = nonRepudiation, digitalSignature, keyEncipherment
subjectAltName = @alt_names

[alt_names]
DNS.1 = ${LDAP_HOST}
DNS.2 = localhost
DNS.3 = *.${LDAP_DOMAIN}
IP.1 = 127.0.0.1
EOF

    openssl req -new -key ldap.key -out ldap.csr -config ldap.cnf
    openssl x509 -req -days ${CERT_DAYS} -in ldap.csr -CA ca.crt -CAkey ca.key \
        -CAcreateserial -out ldap.crt -extensions v3_req -extfile ldap.cnf

    rm -f ldap.csr ldap.cnf
    echo "[OK] LDAP server certificate generated"
else
    echo "[SKIP] LDAP server certificate already exists"
fi
echo ""

# Set permissions
echo "3. Setting permissions..."
chmod 644 ca.crt ldap.crt
chmod 600 ca.key ldap.key
echo "[OK] Permissions set"
echo ""

# Verify certificates
echo "4. Verifying certificates..."
echo "   CA certificate:"
openssl x509 -in ca.crt -noout -subject -dates | head -3
echo ""
echo "   LDAP server certificate:"
openssl x509 -in ldap.crt -noout -subject -dates | head -3
echo ""

echo "=========================================="
echo "[OK] Certificate Generation Complete"
echo "=========================================="
echo ""
echo "Generated files:"
echo "  - ${CERT_DIR}/ca.crt (CA certificate)"
echo "  - ${CERT_DIR}/ca.key (CA private key)"
echo "  - ${CERT_DIR}/ldap.crt (LDAP server certificate)"
echo "  - ${CERT_DIR}/ldap.key (LDAP server private key)"
echo ""
echo "Security Note:"
echo "  - Keep ca.key and ldap.key secure - never share them"
echo "  - Copy ca.crt to client machines for TLS verification"
echo "  - Consider using a production CA for production deployments"
echo ""
echo "To use LDAPS:"
echo "  - Copy ca.crt to client machines: /etc/openldap/cacerts/ca.crt"
echo "  - Configure clients to trust the CA"
echo "  - Connect using ldaps://hostname:636"
